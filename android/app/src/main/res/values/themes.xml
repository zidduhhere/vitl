<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Clinical Instrument App Theme (light) -->
    <style name="Theme.VitalLink" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/signal_teal</item>
        <item name="colorPrimaryDark">@color/paper</item>
        <item name="colorAccent">@color/signal_teal</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/paper</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_muted</item>
        <item name="android:textColorHint">@color/ink_faint</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/paper</item>

        <!-- Default Typeface to Monospace where applicable -->
        <item name="android:typeface">monospace</item>
    </style>

    <!-- Numpad Button Styles -->
    <style name="NumpadButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_numpad_button</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="NumpadActionButton" parent="NumpadButton">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
