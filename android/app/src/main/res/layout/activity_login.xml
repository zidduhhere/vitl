<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vanta_black"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvAuthHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WORKER AUTH"
        android:textColor="@color/neon_teal"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvPinPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTER PIN"
        android:textColor="@color/text_dim"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAuthHeader"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Worker ID Input -->
    <EditText
        android:id="@+id/etWorkerID"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="#15171C"
        android:hint="WORKER ID"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_bright"
        android:textColorHint="@color/slate_grey"
        android:fontFamily="monospace"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvPinPrompt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PIN Display -->
    <TextView
        android:id="@+id/tvPinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="_ _ _ _"
        android:textColor="@color/neon_teal"
        android:textSize="48sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/etWorkerID"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Numpad Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="48dp"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="true"
        app:layout_constraintTop_toBottomOf="@id/tvPinDisplay"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Row 1 -->
        <Button android:id="@+id/btn1" style="@style/NumpadButton" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/NumpadButton" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/NumpadButton" android:text="3" />

        <!-- Row 2 -->
        <Button android:id="@+id/btn4" style="@style/NumpadButton" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/NumpadButton" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/NumpadButton" android:text="6" />

        <!-- Row 3 -->
        <Button android:id="@+id/btn7" style="@style/NumpadButton" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/NumpadButton" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/NumpadButton" android:text="9" />

        <!-- Row 4 -->
        <Button android:id="@+id/btnClear" style="@style/NumpadActionButton" android:text="CLR" android:textColor="@color/tactical_red" />
        <Button android:id="@+id/btn0" style="@style/NumpadButton" android:text="0" />
        <Button android:id="@+id/btnEnter" style="@style/NumpadActionButton" android:text="ENT" android:textColor="@color/neon_teal" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
