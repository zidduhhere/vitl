<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/paper"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Terminal Status Log -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_ticker"
            android:padding="16dp"
            android:text="[SYS] OFFLINE"
            android:textColor="@color/signal_teal"
            android:fontFamily="sans-serif-medium"
            android:textSize="14sp" />

        <Space android:layout_width="match_parent" android:layout_height="32dp"/>

        <!-- Connection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVER CONNECTION"
            android:textColor="@color/ink_muted"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etServer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="IP ADDRESS"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:text="172.21.6.113"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:fontFamily="sans-serif"/>

            <EditText
                android:id="@+id/etPort"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:hint="PORT"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:text="9000"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etPatientID"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:hint="PATIENT ID"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:text="1001"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:fontFamily="sans-serif" />

            <Button
                android:id="@+id/btnAddPatient"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_outline_button"
                android:text="+ ADD NEW"
                android:textColor="@color/signal_teal"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/signal_teal"
                android:text="Connect to Server"
                android:textColor="@color/surface"
                android:textStyle="bold"
                android:fontFamily="sans-serif" />

            <Button
                android:id="@+id/btnEndSession"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button"
                android:text="Disconnect"
                android:textColor="@color/ink"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:enabled="false" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="40dp"/>

        <!-- Device Emulator Connection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEDICAL DEVICE CONNECTION"
            android:textColor="@color/ink_muted"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etDeviceServer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_input_field"
                android:hint="DEVICE IP"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:text="172.21.6.113"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:fontFamily="sans-serif"/>

            <EditText
                android:id="@+id/etDevicePort"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:hint="PORT"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:text="8081"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
        
        <Button
            android:id="@+id/btnConnectDevice"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outline_button"
            android:text="Sync Vitals from Device"
            android:textColor="@color/ink"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

        <Space android:layout_width="match_parent" android:layout_height="40dp"/>

        <!-- Vitals Grid -->
        <TextView
            android:id="@+id/tvVitalsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TELEMETRY"
            android:textColor="@color/ink_muted"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/llVitals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HR -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:text="HR" android:layout_width="64dp" android:layout_height="wrap_content" android:textColor="@color/ink" android:textStyle="bold" android:fontFamily="sans-serif"/>
                <Button android:id="@+id/btnHrMinus" android:text="-" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
                <EditText android:id="@+id/etHR" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/bg_input_field" android:inputType="number" android:text="78" android:gravity="center" android:textColor="@color/ink" android:fontFamily="sans-serif" android:textSize="18sp"/>
                <Button android:id="@+id/btnHrPlus" android:text="+" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
            </LinearLayout>

            <!-- SpO2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:text="SPO2" android:layout_width="64dp" android:layout_height="wrap_content" android:textColor="@color/ink" android:textStyle="bold" android:fontFamily="sans-serif"/>
                <Button android:id="@+id/btnSpo2Minus" android:text="-" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
                <EditText android:id="@+id/etSpO2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/bg_input_field" android:inputType="number" android:text="98" android:gravity="center" android:textColor="@color/ink" android:fontFamily="sans-serif" android:textSize="18sp"/>
                <Button android:id="@+id/btnSpo2Plus" android:text="+" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
            </LinearLayout>

            <!-- SYS -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:text="SYS" android:layout_width="64dp" android:layout_height="wrap_content" android:textColor="@color/ink" android:textStyle="bold" android:fontFamily="sans-serif"/>
                <Button android:id="@+id/btnSysMinus" android:text="-" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
                <EditText android:id="@+id/etBPSys" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/bg_input_field" android:inputType="number" android:text="120" android:gravity="center" android:textColor="@color/ink" android:fontFamily="sans-serif" android:textSize="18sp"/>
                <Button android:id="@+id/btnSysPlus" android:text="+" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
            </LinearLayout>

            <!-- DIA -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <TextView android:text="DIA" android:layout_width="64dp" android:layout_height="wrap_content" android:textColor="@color/ink" android:textStyle="bold" android:fontFamily="sans-serif"/>
                <Button android:id="@+id/btnDiaMinus" android:text="-" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
                <EditText android:id="@+id/etBPDia" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/bg_input_field" android:inputType="number" android:text="80" android:gravity="center" android:textColor="@color/ink" android:fontFamily="sans-serif" android:textSize="18sp"/>
                <Button android:id="@+id/btnDiaPlus" android:text="+" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
            </LinearLayout>

            <!-- TEMP -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <TextView android:text="TEMP" android:layout_width="64dp" android:layout_height="wrap_content" android:textColor="@color/ink" android:textStyle="bold" android:fontFamily="sans-serif"/>
                <Button android:id="@+id/btnTempMinus" android:text="-" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
                <EditText android:id="@+id/etTemp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/bg_input_field" android:inputType="numberDecimal" android:text="36.8" android:gravity="center" android:textColor="@color/ink" android:fontFamily="sans-serif" android:textSize="18sp"/>
                <Button android:id="@+id/btnTempPlus" android:text="+" android:layout_width="48dp" android:layout_height="match_parent" android:background="@drawable/bg_outline_button" android:textColor="@color/ink" android:textSize="20sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSendVitals"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_outline_button"
                android:text="TX VITALS"
                android:textColor="@color/signal_teal"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:enabled="false" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="40dp"/>

        <!-- Media -->
        <TextView
            android:id="@+id/tvMediaHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IMAGING &amp; AUDIO"
            android:textColor="@color/ink_muted"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_outline_button"
                android:drawableStart="@android:drawable/ic_menu_camera"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="IMAGE SCAN"
                android:textColor="@color/signal_teal"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:enabled="false" />

            <Button
                android:id="@+id/btnAudio"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button"
                android:drawableStart="@android:drawable/ic_btn_speak_now"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="AUDIO"
                android:textColor="@color/signal_teal"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:enabled="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMediaProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IDLE"
            android:textColor="@color/ink_muted"
            android:fontFamily="sans-serif-medium"
            android:textSize="12sp"
            android:layout_marginTop="16dp"
            android:gravity="center" />
            
        <Space android:layout_width="match_parent" android:layout_height="40dp"/>

    </LinearLayout>
</ScrollView>
